@article{kluegel_legitimation_1999,
  title = {The {{Legitimation}} of {{Capitalism}} in the {{Postcommunist Transition Public Opinion}} about {{Market Justice}}, 1991---1996},
  author = {Kluegel, James R. and Mason, David S. and Wegener, Bernd},
  year = 1999,
